<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="top.wyhao.admin.system.mapper.DictMapper">
    <select id="listByDictType" resultType="top.wyhao.starter.web.core.model.resp.LabelValueResp">
        SELECT label, value, extra
        FROM sys_dict
        WHERE enabled = true AND dict_type = #{dictType}
        ORDER BY sort
    </select>
</mapper>